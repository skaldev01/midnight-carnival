# Copy this file to `.env.local` and fill in your real values.
# `.env.local` is gitignored — never commit real secrets.

# =============================================
# AI providers
# =============================================

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (ChatGPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional model overrides
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o

# =============================================
# Google Sign-In + Drive sync (NextAuth)
# =============================================
#
# Setup (one time):
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create a new project or select an existing one
#   3. APIs & Services → Library → enable "Google Drive API"
#   4. APIs & Services → Credentials → Create Credentials → OAuth client ID
#        • Application type: Web application
#        • Authorized redirect URIs:
#            http://localhost:3000/api/auth/callback/google
#   5. Copy the Client ID and Client Secret here.
#   6. OAuth consent screen → add scope "auth/drive.file"
#      (only needed if your app is in "External" mode and you want non-test users)
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth — required. Generate a random 32-byte secret:
#   openssl rand -base64 32
# (or use any 32+ char random string)
NEXTAUTH_SECRET=

# Only required in production. For local dev, NextAuth auto-detects http://localhost:3000.
# NEXTAUTH_URL=http://localhost:3000
